<!-- ═══════════════════════════════════════════════════
  SECTION 2 — MEGA-DEALS
═══════════════════════════════════════════════════ -->
<div class="section-block">
  <div class="sec-header" id="hdr-mega" onclick="toggle('mega')">
    <span class="sec-icon">⭐</span>
    <span class="sec-title">Mega-Deals — Corporate / Platform-Level</span>
    <span class="sec-count">2 deals · ~$38B total</span>
    <span class="chevron">▾</span>
  </div>
  <div class="sec-body" id="body-mega">
  <div class="table-wrap"><table>
    <colgroup><col class="c-num"><col class="c-seller"><col class="c-buyer"><col class="c-val"><col class="c-time"><col class="c-type"><col class="c-cmt"></colgroup>
    <thead><tr><th>#</th><th>Seller / Target</th><th>Buyer / Investor</th><th>Deal Value</th><th>Timing</th><th>Deal Type</th><th>Key Takeaways &amp; Comments</th></tr></thead>
    <tbody>

    <tr>
      <td class="num">3</td>
      <td>
        <div class="party-cell">
          <span class="p-label">Target</span>
          <div class="party-row">
            <div class="logo-box"><img
              src="https://upload.wikimedia.org/wikipedia/commons/thumb/6/67/AES_Corporation_logo.svg/200px-AES_Corporation_logo.svg.png"
              onerror="this.closest('.logo-box').outerHTML='<div class=\'logo-init\' style=\'background:#003087\'>AES</div>'"
              alt="AES"></div>
            <span class="party-name">AES Corporation</span>
          </div>
          <p class="party-sub">Global power co.; 11.8 GW signed clean energy supply agreements; large US renewables &amp; regulated utility franchise</p>
        </div>
      </td>
      <td>
        <div class="party-cell">
          <span class="p-label">Buyer Consortium</span>
          <div class="party-row" style="margin-bottom:.4rem">
            <div class="logo-box"><img
              src="https://upload.wikimedia.org/wikipedia/commons/thumb/1/18/BlackRock_wordmark.svg/200px-BlackRock_wordmark.svg.png"
              onerror="this.closest('.logo-box').outerHTML='<div class=\'logo-init\' style=\'background:#231F20\'>BLK</div>'"
              alt="BlackRock"></div>
            <span class="party-name buyer" style="font-size:11px">GIP (BlackRock)</span>
          </div>
          <div class="party-row">
            <div class="logo-box"><img
              src="https://upload.wikimedia.org/wikipedia/commons/thumb/b/b3/EQT_AB_logo.svg/200px-EQT_AB_logo.svg.png"
              onerror="this.closest('.logo-box').outerHTML='<div class=\'logo-init\' style=\'background:#E4003A\'>EQT</div>'"
              alt="EQT"></div>
            <span class="party-name buyer" style="font-size:11px">EQT Infrastructure VI</span>
          </div>
          <p class="party-sub">+ co-investors CalPERS &amp; Qatar Investment Authority</p>
        </div>
      </td>
      <td class="val">$33.4B EV<br><small style="font-family:inherit;font-size:10px;color:var(--muted)">$10.7B equity<br>$15.00/sh cash</small></td>
      <td class="timing">1Q '26<br><small>Ann. Mar 2, 2026<br>Close: Late '26 / Early '27</small></td>
      <td><span class="tag take">Take-Private</span></td>
      <td class="cmt">Largest clean energy infrastructure take-private of the current cycle. GIP/EQT consortium acquires AES — the world's largest corporate clean energy supplier (11.8 GW contracted to major tech firms) — at a 40.3% premium to its 30-day VWAP. Deal rationale: AES needed capital to fund US renewables and data center power demand but could not do so without dividend cuts or dilutive equity issuance. CalPERS and QIA co-underwrite. Close pending shareholder vote and multi-jurisdiction regulatory approvals.
        <div class="sources">
          <a class="src" href="https://www.esgtoday.com/blackrock-eqt-lead-33-billion-acquisition-of-aes/" target="_blank">ESG Today</a>
          <a class="src" href="https://www.aes.com/energy-insights/consortium-led-global-infrastructure-partners-and-eqt-agrees-acquire-aes" target="_blank">AES Press Release</a>
          <a class="src" href="https://www.bloomberg.com/news/articles/2026-03-02/blackrock-s-gip-and-eqt-to-buy-aes-for-10-7-billion" target="_blank">Bloomberg</a>
        </div>
      </td>
    </tr>

    <tr>
      <td class="num">4</td>
      <td>
        <div class="party-cell">
          <span class="p-label">Target (TPG's stake)</span>
          <div class="party-row">
            <div class="logo-box"><img
              src="https://upload.wikimedia.org/wikipedia/commons/thumb/1/14/Intersect_Power_logo.png/200px-Intersect_Power_logo.png"
