      <td>
        <div class="party-cell">
          <span class="p-label">Buyer</span>
          <div class="party-row">
            <div class="logo-box"><img
              src="https://upload.wikimedia.org/wikipedia/commons/thumb/a/a9/Amazon_logo.svg/200px-Amazon_logo.svg.png"
              onerror="this.closest('.logo-box').outerHTML='<div class=\'logo-init\' style=\'background:#FF9900;color:#000\'>AMZ</div>'"
              alt="Amazon"></div>
            <span class="party-name buyer">Amazon / AWS</span>
          </div>
          <p class="party-sub">Outbid Puget Sound Energy ($82M) at bankruptcy auction</p>
