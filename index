</div>


<!-- ═══════════════════════════════════════════════════
  SECTION 3 — PLATFORM / DEVELOPER
═══════════════════════════════════════════════════ -->
<div class="section-block">
  <div class="sec-header" id="hdr-platform" onclick="toggle('platform')">
