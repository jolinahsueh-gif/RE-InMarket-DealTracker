<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Q1 2026 — Renewable Energy & Sustainable Infrastructure M&A Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --navy:      #1B3A5C;
  --navy-l:    #24527F;
  --navy-pale: #EEF3F8;
  --navy-mid:  #C8D8E8;
  --accent:    #2E7D99;
  --gold:      #9A6010;
  --red:       #8B2A2A;
  --green:     #2E7A4F;
  --purple:    #5A3A7A;
  --teal:      #2A6A6A;
  --steel:     #3D5F7A;
  --bg:        #FFFFFF;
  --surface:   #F7F9FC;
  --border:    #DDE4EC;
  --text:      #1A2332;
  --muted:     #5E7491;
  --row-hover: #EAF1F8;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);font-size:13px;line-height:1.5;padding:2.5rem 2rem 5rem}

/* PAGE HEADER */
.page-header{max-width:1600px;margin:0 auto 1.6rem;padding-bottom:1rem;border-bottom:3px solid var(--navy)}
.eyebrow{font-size:10px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:.3rem}
h1{font-size:1.25rem;font-weight:700;color:var(--navy);line-height:1.25}
h1 em{font-style:normal;color:var(--accent)}
.meta-row{display:flex;gap:2rem;margin-top:.5rem;flex-wrap:wrap;font-size:11px;color:var(--muted)}
.meta-row span strong{color:var(--text);font-weight:600}

/* KPI BAR */
.kpi-bar{max-width:1600px;margin:0 auto 1.6rem;display:flex;gap:.8rem;flex-wrap:wrap}
.kpi{flex:1 1 140px;background:var(--navy);border-radius:6px;padding:.8rem 1rem;color:#fff}
.kpi-num{font-size:1.55rem;font-weight:700;display:block;line-height:1;margin-bottom:.2rem}
.kpi-num.gold{color:#F0B450}.kpi-num.teal{color:#7ECFEA}.kpi-num.green{color:#7CE8A8}
.kpi-label{font-size:9.5px;font-weight:500;text-transform:uppercase;letter-spacing:.07em;color:#A8C4D8}

/* CONTROLS */
.controls{max-width:1600px;margin:0 auto 1rem;display:flex;align-items:center;gap:.6rem;flex-wrap:wrap}
.ctrl-btn{display:inline-flex;align-items:center;gap:.35rem;padding:.38rem .8rem;border:1px solid var(--border);border-radius:4px;background:var(--surface);color:var(--navy);font-size:11px;font-weight:600;cursor:pointer;transition:all .15s;user-select:none;font-family:inherit}
.ctrl-btn:hover{background:var(--navy-pale);border-color:var(--navy-mid)}
.ctrl-hint{font-size:11px;color:var(--muted)}

/* SECTION BLOCK */
.section-block{max-width:1600px;margin:0 auto .9rem}

.sec-header{
  display:flex;align-items:center;gap:.6rem;
  padding:.65rem 1rem;
  background:var(--navy);
  border-radius:6px 6px 0 0;
  cursor:pointer;user-select:none;
}
.sec-header.collapsed{border-radius:6px}
.sec-icon{font-size:.85rem;line-height:1}
.sec-title{font-size:10.5px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:#C8DCF0;flex:1}
.sec-count{font-size:10px;color:#7EAED4;font-weight:500;white-space:nowrap}
.chevron{margin-left:.5rem;color:#7EAED4;transition:transform .25s;line-height:1}
.sec-header.collapsed .chevron{transform:rotate(-90deg)}

/* SECTION BODY */
.sec-body{overflow:hidden;transition:max-height .35s cubic-bezier(.4,0,.2,1),opacity .2s ease;max-height:4000px;opacity:1}
.sec-body.collapsed{max-height:0;opacity:0;pointer-events:none}

/* TABLE */
.table-wrap{border:1px solid var(--border);border-top:none;border-radius:0 0 8px 8px;overflow-x:auto;box-shadow:0 2px 8px rgba(27,58,92,.06)}
table{width:100%;border-collapse:collapse;min-width:1060px;table-layout:fixed}
col.c-num   {width:32px}
col.c-seller{width:185px}
col.c-buyer {width:185px}
col.c-val   {width:105px}
col.c-time  {width:108px}
col.c-type  {width:120px}
col.c-cmt   {width:auto}

thead tr{background:var(--navy-pale);border-bottom:2px solid var(--navy-mid)}
th{font-size:9.5px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--navy);padding:.65rem .85rem;text-align:left;white-space:nowrap}

tbody tr{border-bottom:1px solid var(--border);transition:background .1s}
tbody tr:nth-child(even):not(.wind-exit){background:var(--surface)}
tbody tr:hover:not(.wind-exit){background:var(--row-hover)}

td{padding:.75rem .85rem;vertical-align:top;font-size:12px;line-height:1.55;overflow:hidden}
td.num{color:var(--muted);font-size:11px;text-align:center;padding-top:.9rem}
td.val{font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:600;color:var(--gold)}
td.timing{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--navy)}
td.cmt{color:var(--text)}

/* PARTY CELL WITH LOGO */
.party-cell{display:flex;flex-direction:column;gap:.4rem}
.p-label{font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
.party-row{display:flex;align-items:center;gap:.55rem}

/* Logo container */
.logo-box{
  width:32px;height:32px;
  border-radius:6px;
  border:1px solid var(--border);
  background:#fff;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;overflow:hidden;
  box-shadow:0 1px 3px rgba(0,0,0,.08);
}
.logo-box img{width:28px;height:28px;object-fit:contain;display:block}
.logo-init{
  width:32px;height:32px;border-radius:6px;
  display:flex;align-items:center;justify-content:center;
  font-size:10px;font-weight:800;color:#fff;
  flex-shrink:0;letter-spacing:-.5px;
}
.party-name{font-weight:600;font-size:12px;color:var(--navy);line-height:1.3}
.party-name.buyer{color:var(--accent)}
.party-sub{font-size:10.5px;color:var(--muted);line-height:1.4;margin-top:.1rem}
.party-divider{border:none;border-top:1px dashed var(--border);margin:.35rem 0}

/* DEAL TYPE BADGES */
.tag{display:inline-block;border-radius:3px;padding:.16rem .4rem;font-size:9px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#fff;white-space:nowrap}
.tag.take {background:var(--navy)}
.tag.corp {background:var(--navy-l)}
.tag.asset{background:var(--accent)}
.tag.bkrp {background:var(--red)}
.tag.spac {background:var(--green)}
.tag.exit {background:#7A3020}
.tag.mfg  {background:var(--steel)}
.tag.vert {background:var(--teal)}
.tag.div  {background:var(--purple)}

/* SOURCE LINKS */
.sources{margin-top:.45rem;display:flex;flex-wrap:wrap;gap:.2rem .5rem}
.src{font-size:10px;color:var(--accent);text-decoration:none;font-weight:500;border-bottom:1px dotted var(--accent)}
.src:hover{border-bottom-style:solid}
.src::before{content:"↗ ";opacity:.7;font-size:9px}

/* WIND EXIT */
tr.wind-exit td{background:#FFF5F3}
tr.wind-exit:hover td{background:#FFE9E4}

/* MARKET CONTEXT */
.context{max-width:1600px;margin:1.5rem auto 0;border:1px solid var(--border);border-left:4px solid var(--navy);border-radius:6px;padding:1.1rem 1.4rem;background:var(--surface)}
.context h3{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--navy);margin-bottom:.85rem}
.ctx-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:.7rem}
.ctx-item{background:#fff;border:1px solid var(--border);border-radius:5px;padding:.7rem .9rem;font-size:11.5px;line-height:1.55}
.ctx-item strong{color:var(--navy);font-weight:600;display:block;margin-bottom:.2rem}

/* FOOTER */
footer{max-width:1600px;margin:1.4rem auto 0;font-size:10.5px;color:var(--muted);border-top:1px solid var(--border);padding-top:.8rem;line-height:1.65}
footer a{color:var(--accent);text-decoration:none}
footer a:hover{text-decoration:underline}
</style>
</head>
